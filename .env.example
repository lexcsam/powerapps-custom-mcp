# ============================================================
# PowerApps Custom MCP — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Required: Your Azure tenant ID
AZURE_TENANT_ID=your-tenant-id-here

# Required: Your Dataverse environment URL
DATAVERSE_URL=https://yourorg.crm.dynamics.com

# Required: Azure AD App Registration Client ID
AZURE_CLIENT_ID=your-client-id-here

# Optional: Client Secret (for headless/service principal auth)
# If omitted, the server will use interactive Device Code flow
AZURE_CLIENT_SECRET=

# Optional: Power Platform Environment ID (for management API calls)
# Found in Power Platform Admin Center > Environments > Details
POWER_PLATFORM_ENV_ID=

# ============================================================
# Canvas App Authoring (optional — for canvas_* tools)
# ============================================================
# Extract these from your Power Apps Studio URL:
# https://make.powerapps.com/e/{ENV_ID}/canvas/?action=edit&app-id=.../{APP_ID}
# Requires .NET 10 SDK and an open Studio coauthoring session.

# Canvas Environment ID (e.g., Default-91bee3d9-0c15-4f17-8624-c92bb8b36ead)
CANVAS_ENVIRONMENT_ID=

# Canvas App ID (GUID, e.g., 6fc3e3d1-292b-4281-8826-577f78512e56)
CANVAS_APP_ID=

# Cluster category: 'prod' for make.powerapps.com, 'test' for other hosts
CANVAS_CLUSTER_CATEGORY=prod
