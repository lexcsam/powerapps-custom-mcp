  "license": "MIT",
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
