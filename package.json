  "description": "All-in-one MCP server for Power Platform: environments, solutions, Dataverse, flows, connectors, app sharing, and templates",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "powerapps-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
